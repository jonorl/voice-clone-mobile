{
  "expo": {
    "name": "voice-clone-mobile",
    "slug": "voice-clone-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "voiceclonemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
        },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen"
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
